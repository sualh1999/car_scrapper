# Telegram API credentials
API_ID=your_api_id
API_HASH=your_api_hash
SESSION_STRING=your_pyrogram_session_string
BOT_TOKEN=your_telegram_bot_token

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# App settings
MY_CHANNEL_ID=your_target_channel_username_or_id
ADMIN_ID=123456789
ADMIN_USERNAME=your_admin_username
CRON_SECRET=replace_with_strong_secret
WEBHOOK_URL=https://your-domain.example
SESSION_NAME=/tmp/my_account

# AI settings
# Default uses Hugging Face Router OpenAI-compatible endpoint.
AI_BASE_URL=https://router.huggingface.co/v1
# Optional explicit API key for custom endpoints.
AI_API_KEY=
HF_TOKEN=your_hf_token
# Optional: multiple tokens for rotation
# HF_TOKEN__0=your_hf_token_0
# HF_TOKEN__1=your_hf_token_1
AI_MODEL_NAME=Qwen/Qwen3-Coder-Next:novita

# Example for your HF Space:
# AI_BASE_URL=https://Salihq19-qwen0ai.hf.space/v1
# AI_MODEL_NAME=model.gguf
